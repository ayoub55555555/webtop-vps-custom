{
  "name": "Webtop VPS Custom",
  "description": "Ubuntu XFCE Desktop with SSH and Tmate pre-installed",
  "keywords": ["vps", "ubuntu", "docker", "ssh", "tmate", "remote-desktop"],
  "repository": "https://github.com/ayoub55555555/webtop-vps-custom",
  "env": {
    "PUID": {
      "description": "User ID",
      "value": "1000"
    },
    "PGID": {
      "description": "Group ID",
      "value": "1000"
    },
    "TZ": {
      "description": "Timezone",
      "value": "UTC"
    }
  },
  "image": "ghcr.io/ayoub55555555/webtop-vps-custom:main",
  "scripts": {
    "postdeploy": "echo 'Deployment successful'"
  }
}
